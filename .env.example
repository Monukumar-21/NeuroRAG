APP_NAME=NeuroRAG
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

NEON_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require
REQUIRE_DATABASE=false

ENABLE_HITL=false
REQUEST_TIMEOUT_SECONDS=60
